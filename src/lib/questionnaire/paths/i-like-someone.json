        { "label": "Heartbroken", "value": "heartbroken" },
        { "label": "Not Sure", "value": "not_sure" }
      ]
    },
    {
      "id": "love_crush_admiration",
      "text": "Do you think this is love, a crush, admiration, or friendship?",
      "type": "multiple_choice",
      "options": [
        { "label": "Love", "value": "love" },
        { "label": "Crush", "value": "crush" },
        { "label": "Admiration", "value": "admiration" },
        { "label": "Friendship", "value": "friendship" },
        { "label": "Unsure", "value": "unsure" }
      ]
    },
    {
      "id": "if_confessed",
      "text": "If they confessed their feelings today, what would you most likely do?",
      "type": "multiple_choice",
      "options": [
        { "label": "Say yes immediately", "value": "say_yes" },
        { "label": "Need time to think", "value": "need_time" },
        { "label": "Stay friends", "value": "stay_friends" },
        { "label": "Say no", "value": "say_no" },
        { "label": "I'm not sure", "value": "not_sure" }
      ]
    }
  ]
}
