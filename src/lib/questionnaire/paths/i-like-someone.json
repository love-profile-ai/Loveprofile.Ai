    {
      "id": "true_self_comfort",
      "text": "Do you feel comfortable being your true self around them?",
      "type": "scale",
      "min": 1,
      "max": 10
    },
    {
      "id": "attraction_type",
      "text": "Are you attracted to them physically, emotionally, or both?",
      "type": "multiple_choice",
      "options": [
        { "label": "Mostly Physical", "value": "mostly_physical" },
        { "label": "Mostly Emotional", "value": "mostly_emotional" },
        { "label": "Both Equally", "value": "both_equally" },
        { "label": "Not Sure", "value": "not_sure" }
      ]
    },
    {
      "id": "trust_level",
      "text": "How much do you trust them?",
      "type": "scale",
      "min": 1,
      "max": 10
    },
    {
      "id": "dating_someone_else",
      "text": "How would you feel if they started dating someone else?",
      "type": "multiple_choice",
      "options": [
        { "label": "Happy for them", "value": "happy" },
        { "label": "Slightly Disappointed", "value": "slightly_disappointed" },
